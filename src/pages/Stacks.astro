        {
            name: "Figma",
            role: "Prototyping",
            icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/figma/figma-original.svg",
        },
        {
            name: "WordPress",
            role: "CMS & Plugin Dev",
            icon: "https://skillicons.dev/icons?i=wordpress",
        },
    ],
    automation: [
        {
            name: "UiPath",
            role: "RPA Development",
            icon: "https://cdn.simpleicons.org/uipath/FA4616",
