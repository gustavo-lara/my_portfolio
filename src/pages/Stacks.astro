---

<html lang="pt-br">
    <head>
        <meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="https://api.iconify.design/lucide:terminal.svg?color=%2300f3ff" />
        <meta name="viewport" content="width=device-width" />
        <title>Stacks | Gustavo Lara</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Syne:wght@700;800&display=swap"
            rel="stylesheet"
        />
    </head>
    <body>
        <Navbar />

        <section class="stacks-section">
            <div class="ambient-glow glow-purple"></div>
            <div class="ambient-glow glow-cyan"></div>

            <div class="container">
                <div class="section-header">
                    <h1 class="section-title">TECH STACK</h1>
                    <div class="title-decoration"></div>
                </div>

                <div class="stack-group">
                    <h2 class="category-title">
                        LANGUAGES
                        <span class="category-count"
                            >{techStack.languages.length}</span
                        >
                    </h2>
                    <div class="tech-grid">
                        {
                            techStack.languages.map((tech, index) => (
                                <div
                                    class="tech-card lang-border"
                                    style={`animation-delay: ${index * 100}ms`}
                                >
                                    <div class="icon-wrapper">
                                        <img
                                            src={tech.icon}
                                            alt={tech.name}
                                            class="tech-icon"
                                            loading="lazy"
                                        />
                                    </div>
                                    <div class="tech-info">
                                        <span class="tech-name">
                                            {tech.name}
                                        </span>
                                        <span class="tech-role">
                                            {tech.role}
                                        </span>
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>

                <div class="stack-group">
                    <h2 class="category-title">
                        FRAMEWORKS & LIBS
                        <span class="category-count"
                            >{techStack.frameworks.length}</span
                        >
                    </h2>
                    <div class="tech-grid">
                        {
                            techStack.frameworks.map((tech, index) => (
                                <div
                                    class="tech-card frame-border"
                                    style={`animation-delay: ${index * 100}ms`}
                                >
                                    <div class="icon-wrapper">
                                        <img
                                            src={tech.icon}
                                            alt={tech.name}
                                            class="tech-icon"
                                            loading="lazy"
                                        />
                                    </div>
                                    <div class="tech-info">
                                        <span class="tech-name">
                                            {tech.name}
                                        </span>
                                        <span class="tech-role">
                                            {tech.role}
                                        </span>
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>

                <div class="stack-group">
                    <h2 class="category-title">
                        AUTOMATION & LOW-CODE
                        <span class="category-count"
                            >{techStack.automation.length}</span
                        >
                    </h2>
                    <div class="tech-grid">
                        {
                            techStack.automation.map((tech, index) => (
                                <div
                                    class="tech-card auto-border"
                                    style={`animation-delay: ${index * 100}ms`}
                                >
                                    <div class="icon-wrapper">
                                        <img
                                            src={tech.icon}
                                            alt={tech.name}
                                            class="tech-icon"
                                            loading="lazy"
                                        />
                                    </div>
                                    <div class="tech-info">
                                        <span class="tech-name">
                                            {tech.name}
                                        </span>
                                        <span class="tech-role">
                                            {tech.role}
                                        </span>
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>

                <div class="stack-group">
                    <h2 class="category-title">
                        TOOLS & PLATFORMS
                        <span class="category-count"
                            >{techStack.tools.length}</span
                        >
                    </h2>
                    <div class="tech-grid">
                        {
                            techStack.tools.map((tech, index) => (
                                <div
                                    class="tech-card tool-border"
                                    style={`animation-delay: ${index * 100}ms`}
                                >
                                    <div class="icon-wrapper">
                                        <img
                                            src={tech.icon}
                                            alt={tech.name}
                                            class="tech-icon"
                                            loading="lazy"
                                        />
                                    </div>
                                    <div class="tech-info">
                                        <span class="tech-name">
                                            {tech.name}
                                        </span>
                                        <span class="tech-role">
                                            {tech.role}
                                        </span>
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
        </section>

        <Footer />
    </body>
</html>
