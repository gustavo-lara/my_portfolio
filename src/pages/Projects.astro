---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import "../styles/Projects.css";
---

<html lang="pt-br">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <title>Projects | Gustavo Lara</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Syne:wght@700;800&family=Fira+Code&display=swap"
            rel="stylesheet"
        />
    </head>
    <body>
        <Navbar />

        <section class="projects-section">
            <div class="ambient-glow glow-purple"></div>
            <div class="ambient-glow glow-cyan"></div>

            <div class="container">
                <div class="section-header">
                    <h1 class="section-title">PROJECTS</h1>
                    <div class="title-decoration"></div>
                </div>

                <div class="coming-soon-wrapper">
                    <div class="terminal-window coming-soon-terminal">
                        <div class="terminal-header">
                            <div class="terminal-controls">
                                <span class="control close"></span>
                                <span class="control minimize"></span>
                                <span class="control maximize"></span>
                            </div>
                            <div class="terminal-tab">deploy.sh</div>
                        </div>
                        <div class="terminal-body">
                            <span class="code-line"><span class="user-path">gustavo@portfolio:~/projects$</span> ./fetch_repositories.sh</span>
                            <span class="code-line system-msg">Connecting to the servers... [OK]</span>
                            <span class="code-line system-msg">Compiling source code...</span>
                            <div class="progress-container">
                                <span class="progress-bar"></span>
                                <span class="progress-text">Loading...</span>
                            </div>
                            <span class="code-line accent-text">&gt;&gt;&gt; STATUS: Coming soon... &lt;&lt;&lt;</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <Footer />
    </body>
</html>